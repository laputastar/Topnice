# ==========================================
# TopNice 数据管线环境变量配置
# ==========================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#
# 所有 Key 仅从环境变量读取，严禁硬编码。
# 已在 .gitignore 中排除，不会提交到 git。
# ==========================================

# ── Firecrawl（HTML 抓取） ─────────────────
# 从 https://www.firecrawl.dev/ 获取
FIRECRAWL_API_KEY=fc-your-key-here

# ── AI 提取引擎 ───────────────────────────
# 主引擎: Cloudflare Workers AI（凭据见下，免费档每日 10,000 neurons 上限）
# 备用引擎: Agnes AI (https://agnes-ai.com, OpenAI 兼容推理模型)
AGNES_API_KEY=ag-your-key-here

# ── Cloudflare Workers AI（硬件分类 + 翻译） ──
# 从 Cloudflare Dashboard → Workers AI 获取
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# ── 可选参数 ────────────────────────────────
# 覆盖翻译模型（默认: @cf/z-ai/glm-4.7-flash）
# CF_TRANSLATE_MODEL=@cf/z-ai/glm-4.7-flash

# 中国网络访问 Cloudflare 的 HTTP 代理（如 http://127.0.0.1:7890）
# CF_PROXY=http://127.0.0.1:7890
