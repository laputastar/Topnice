---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="页面未找到" description="您访问的页面不存在。" lang="zh">
  <section class="page-404">
    <h1>404</h1>
    <p>您访问的页面不存在。</p>
    <a href="/zh/" class="btn-home">返回首页</a>
  </section>
</Layout>

<style>
  .page-404 { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: calc(100vh - 136px); padding: 120px 48px 80px; text-align: center; }
  .page-404 h1 { font-size: 96px; font-weight: 800; color: #e2e8f0; margin-bottom: 16px; letter-spacing: -2px; }
  .page-404 p { font-size: 18px; color: #64748b; margin-bottom: 32px; }
  .btn-home { padding: 12px 28px; border-radius: 12px; background: #0f172a; color: #fff; font-size: 15px; font-weight: 600; text-decoration: none; transition: background 0.2s; font-family: inherit; }
  .btn-home:hover { background: #1e293b; }
  @media (max-width: 768px) { .page-404 { padding: 100px 20px 60px; } .page-404 h1 { font-size: 72px; } }
</style>
