---
import { ui, type Lang } from "../config/i18n";

interface Props {
  creatorName: string;
  creatorAvatar?: string;
  location?: string;
  platform: "kickstarter" | "indiegogo";
  launchedAt: string;
  deadline: string;
  backers: number;
  lang: Lang;
}

const { creatorName, creatorAvatar, location, platform, launchedAt, deadline, backers, lang } = Astro.props;
const t = ui[lang];

const formatDate = (iso: string) => {
  const d = new Date(iso);
  return d.toLocaleDateString(lang === "zh" ? "zh-CN" : "en-US", { year: "numeric", month: "short", day: "numeric" });
};
---

<div class="sidebar-card">
  <h3>{lang === "zh" ? "创建者" : "Creator"}</h3>
  <div class="creator-info">
    <div class="creator-avatar">
      {creatorAvatar ? (
        <img src={creatorAvatar} alt={creatorName} class="avatar-img" />
      ) : (
        <span>{creatorName.charAt(0).toUpperCase()}</span>
      )}
    </div>
    <div>
      <div class="creator-name">{creatorName}</div>
      {location && <div class="creator-location">{location}</div>}
    </div>
  </div>
</div>

<div class="sidebar-card">
  <h3>{lang === "zh" ? "项目信息" : "Project Info"}</h3>
  <div class="project-meta">
    <div class="meta-row">
      <span class="meta-label">{lang === "zh" ? "平台" : "Platform"}</span>
      <span class="meta-value">{platform === "kickstarter" ? "Kickstarter" : "Indiegogo"}</span>
    </div>
    <div class="meta-row">
      <span class="meta-label">{lang === "zh" ? "上线时间" : "Launched"}</span>
      <span class="meta-value">{formatDate(launchedAt)}</span>
    </div>
    <div class="meta-row">
      <span class="meta-label">{lang === "zh" ? "截止时间" : "Deadline"}</span>
      <span class="meta-value">{formatDate(deadline)}</span>
    </div>
    <div class="meta-row">
      <span class="meta-label">{t.backers}</span>
      <span class="meta-value">{backers.toLocaleString()}</span>
    </div>
  </div>
</div>

<style>
  .sidebar-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 24px;
    margin-bottom: 16px;
  }
  .sidebar-card h3 {
    font-size: 14px;
    font-weight: 600;
    color: #0f172a;
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .creator-info {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .creator-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, #f97316, #ef4444);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 20px;
    font-weight: 700;
    overflow: hidden;
    flex-shrink: 0;
  }
  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .creator-name {
    font-size: 15px;
    font-weight: 600;
    color: #0f172a;
  }
  .creator-location {
    font-size: 13px;
    color: #94a3b8;
  }
  .project-meta {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 1px solid #f1f5f9;
  }
  .meta-row:last-child {
    border-bottom: none;
  }
  .meta-label {
    font-size: 13px;
    color: #94a3b8;
  }
  .meta-value {
    font-size: 13px;
    color: #0f172a;
    font-weight: 500;
  }
</style>
