---
import Layout from "../../layouts/Layout.astro";
import ProgressBar from "../../components/ProgressBar.astro";
import AdUnit from "../../components/AdUnit.astro";
import { allProjects } from "../../data/projects";
import { fm, type AiTier } from "../../config/format";

const { project, lang = "en" } = Astro.props;
const isZH = lang === "zh";
const isKS = project.platform === "kickstarter";
const isEnded = project.state !== "live";
const displayName = isZH ? (project.nameZh ?? project.name) : (project.name || "");
const ogImage = project.image_1024x576 || project.image_med || "https://topnice.com/og-default.png";
const projectUrl = project.url || "#";
const baseUrl = isZH ? "/zh" : "";

const bc = project.backers_count || 0;
const pct = project.percent_funded || 0;
const deadlineMs = project.deadline ? new Date(project.deadline).getTime() : null;
const daysLeft = (deadlineMs && !isNaN(deadlineMs)) ? Math.max(0, Math.ceil((deadlineMs - Date.now()) / 86400000)) : null;
const dl = daysLeft;
const related = allProjects
  .filter((p) => p.slug !== project.slug
    && p.topnice_category === project.topnice_category
    && p.state === "live")
  .slice(0, 4);
const avgPledged = bc > 0 ? Math.round((project.pledged || 0) / bc) : 0;

// AI field fallbacks -- ZH uses _zh first, EN uses _en first
const aiIntro = isZH
  ? (project.ai_intro_zh || project.ai_intro_en || project.ai_intro || "")
  : (project.ai_intro_en || project.ai_intro || "");
const aiHighlights = isZH
  ? (project.ai_highlights_zh || project.ai_highlights_en || project.ai_highlights || [])
  : (project.ai_highlights_en || project.ai_highlights || []);
// Normalize specs to [label, value] pairs. Handles array [l,v], string "l | v" (translated), "l: v" (original EN).
const normalizeSpecs = (specs) =>
  (specs || []).map((s) => {
    if (Array.isArray(s) && s.length >= 2) return [String(s[0]), String(s[1])];
    if (typeof s === "string") {
      const pipe = s.indexOf(" | ");
      if (pipe > -1) return [s.slice(0, pipe).trim(), s.slice(pipe + 3).trim()];
      const colon = s.indexOf(": ");
      if (colon > -1) return [s.slice(0, colon).trim(), s.slice(colon + 2).trim()];
      return ["", s.trim()];
    }
    return ["", String(s)];
  });
const aiSpecs = normalizeSpecs(isZH
  ? (project.ai_specs_zh || project.ai_specs_en || project.ai_specs)
  : (project.ai_specs_en || project.ai_specs));
const aiTiers = isZH ? (project.ai_tiers_zh || project.ai_tiers || []) : (project.ai_tiers || []);
const aiRisks = isZH
  ? (project.ai_risks_zh || project.ai_risks_en || project.ai_risks || "")
  : (project.ai_risks_en || project.ai_risks || "");
const aiRisksStructured = isZH
  ? (project.ai_risks_structured_zh || project.ai_risks_structured_en || project.ai_risks_structured || null)
  : (project.ai_risks_structured_en || project.ai_risks_structured || null);
const rawDesc = isZH
  ? (project.ai_description_zh || project.ai_description_en)
  : (project.ai_description_en);
const aiDescription = Array.isArray(rawDesc) ? rawDesc : (rawDesc ? [rawDesc] : []);
const firstSeen = project.first_seen ? new Date(project.first_seen).toLocaleDateString("en-US", { month: "short", day: "numeric" }) : null;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: project.name,
  description: `${project.platform === "kickstarter" ? "Kickstarter" : "Indiegogo"} project. ${fm(project.pledged)} from ${bc.toLocaleString()} backers.`,
  image: project.image_1024x576 || project.image_med,
};

// UI text dictionary
const T = isZH ? {
  about: "项目介绍",
  highlights: "核心亮点",
  specs: "技术规格",
  specLabel: "规格",
  specDetail: "详情",
  tiers: "回报档位",
  backersLabel: "支持者",
  daysLeftLabel: "剩余",
  tiersLabel: "回报档位",
  viewTiersLabel: "查看档位",
  ctaTiersTitle: "\u{1F381} 查看所有回报档位",
  ctaTiersDesc: "点击下方按钮在原始 {p} 页面查看所有档位价格、内容和预计发货信息。",
  ctaTiersBtn: "查看所有档位",
  risks: "风险与挑战",
  insights: "项目洞察",
  scoreLabel: "TopNice 评分",
  avgPledgeLabel: "平均认捐",
  trackedSince: "追踪起始",
  fundedLabel: "已达成",
  updatesTitle: "项目更新",
  updatesDesc: "开发进度、发货时间线和公告",
  updatesLink: "查看所有更新",
  creatorSection: "创作者",
  creatorLabel: "创作者",
  creatorFallback: "创作者",
  igCreatorFallback: "Indiegogo 创作者",
  projectInfo: "项目信息",
  platform: "平台",
  launched: "启动",
  deadline: "截止",
  backersMeta: "支持者",
  origin: "来源",
  currency: "币种",
  endedNotice: "该项目已结束众筹",
  backOnKS: "在 Kickstarter 上支持",
  backOnIG: "在 Indiegogo 上支持",
  share: "分享",
  relatedTitle: "相关项目",
  pledgeGoal: isKS ? "已筹 {p}，目标 {g}" : "Indiegogo 灵活筹资",
  flexFunding: "Indiegogo 灵活筹资",
  viewTiersSuffix: "",
  tierBackers: "{n} 位支持者",
  blurbMain: project.blurbZh || project.blurb,
  blurbFallback: (project.blurbZh || project.blurb || "").replace(/\n/g, ' ').split('.')[0],
  creatorBio: project.ai_creator_bio_zh || project.ai_creator_bio_en || project.ai_creator_bio,
  creatorName: project.creator_name || (isKS ? "创作者" : "Indiegogo 创作者"),
  
} : {
  about: "About This Project",
  highlights: "Key Highlights",
  specs: "Technical Specs",
  specLabel: "Spec",
  specDetail: "Details",
  tiers: "Reward Tiers",
  backersLabel: "backers",
  daysLeftLabel: "days to go",
  tiersLabel: "reward tiers",
  viewTiersLabel: "View Tiers",
  ctaTiersTitle: "\u{1F381} View All Reward Tiers",
  ctaTiersDesc: "Click below to view all tiers with pricing, contents, and estimated shipping on the original {p} page.",
  ctaTiersBtn: "View All Tiers",
  risks: "Risks & Challenges",
  insights: "Project Insights",
  scoreLabel: "TopNice Score",
  avgPledgeLabel: "Avg. Pledge per Backer",
  trackedSince: "Tracked Since",
  fundedLabel: "Funded",
  updatesTitle: "Project Updates",
  updatesDesc: "Development progress, shipping timeline, and announcements",
  updatesLink: "View all updates",
  creatorSection: "Creator",
  creatorLabel: "Creator",
  creatorFallback: "Creator",
  igCreatorFallback: "Indiegogo Creator",
  projectInfo: "Project Info",
  platform: "Platform",
  launched: "Launched",
  deadline: "Deadline",
  backersMeta: "Backers",
  origin: "Origin",
  currency: "Currency",
  endedNotice: "This project has ended crowdfunding",
  backOnKS: "Back on Kickstarter",
  backOnIG: "Back this project on Indiegogo",
  share: "Share",
  relatedTitle: "Related Projects",
  pledgeGoal: isKS ? "pledged of {g} goal" : "Indiegogo Flexible Funding",
  flexFunding: "Indiegogo Flexible Funding",
  viewTiersSuffix: "on " + (isKS ? "Kickstarter" : "Indiegogo"),
  tierBackers: "{n} backers",
  blurbMain: project.blurb,
  blurbFallback: isKS ? project.blurb : (project.blurb || "").replace(/\n/g, ' ').split('.')[0] + '.',
  creatorBio: project.ai_creator_bio_en || project.ai_creator_bio,
  creatorName: project.creator_name || (isKS ? "Creator" : "Indiegogo Creator"),
};
---

<Layout
  title={displayName}
  description={`${displayName} - ${isKS ? "Kickstarter" : "Indiegogo"} crowdfunding project. ${fm(project.pledged)} raised from ${bc.toLocaleString()} backers.`}
  image={ogImage}
  lang={lang}
  ogType="product"
  structuredData={structuredData}
>
  <!-- Hero -->
  <section class="project-hero">
    <div class="project-hero-inner">
      <div class="project-gallery">
        {project.image_1024x576 ? <img src={project.image_1024x576} alt={displayName} class="gallery-img" /> : project.image_med ? <img src={project.image_med} alt={displayName} class="gallery-img" /> : <span class="gallery-placeholder">&#x1F4E6;</span>}
        {isKS && project.video_url && <button class="video-overlay-btn" id="watch-video-btn" type="button" aria-label="Play video">&#9654;</button>}
      </div>

      <!-- Video Modal (KS only) -->
      {isKS && (
        <div class="video-modal" id="video-modal">
          <button class="video-close" id="video-close" aria-label="Close video">&times;</button>
          <video id="video-player" controls preload="none">
            <source src={project.video_url || ""} type="video/mp4" />
          </video>
        </div>
      )}

      <div class="project-info">
        <div class="project-category">{project.topnice_category || project.category}</div>
        <h1 class="project-title">{displayName}</h1>
        {project.blurb && <p class="hero-blurb">{T.blurbFallback}</p>}

        <div class="project-funding">
          <div class="funding-amount">{fm(project.pledged)}</div>
          <div class="funding-goal">
            {project.goal > 0
              ? (isKS ? T.pledgeGoal.replace("{p}", fm(project.pledged)).replace("{g}", fm(project.goal)) : T.flexFunding)
              : T.flexFunding}
          </div>
          <ProgressBar progress={project.goal > 0 ? Math.min(pct, 100) : 100} />
          <div class="funding-stats">
            <div class="funding-stat">
              <span class="funding-stat-value">{bc.toLocaleString()}</span>
              <span class="funding-stat-label">{T.backersLabel}</span>
            </div>
            <div class="funding-stat">
              <span class="funding-stat-value">{dl ?? "—"}</span>
              <span class="funding-stat-label">{T.daysLeftLabel}</span>
            </div>
            {aiTiers.length > 0 ? (
              <div class="funding-stat">
                <span class="funding-stat-value">{aiTiers.length}</span>
                <span class="funding-stat-label">{T.tiersLabel}</span>
              </div>
            ) : (
              <div class="funding-stat">
                <span class="funding-stat-value funding-stat-link">{T.viewTiersLabel} &rarr;</span>
                <span class="funding-stat-label">{isKS ? "Kickstarter" : "Indiegogo"}</span>
              </div>
            )}
          </div>
        </div>

        {isEnded && <div class="ended-notice">&#9203; {T.endedNotice}</div>}

        <div class="project-actions">
          {isKS ? (
            <>
              <a href={projectUrl} target="_blank" rel="noopener noreferrer" class="btn-primary">
                {T.backOnKS} &nearr;
              </a>
            </>
          ) : (
            <>
              <a href={projectUrl} target="_blank" rel="noopener noreferrer" class="btn-ig">{T.backOnIG} &rarr;</a>
              <a href="#" class="btn-secondary">{T.share}</a>
            </>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Details -->
  <section class="project-details">
    <div class="detail-content">
      <h2>{T.about}</h2>

      {aiDescription.length > 0 ? (
        aiDescription.map((para: string) => <p class="desc-text">{para}</p>)
      ) : (
        (aiIntro || project.blurb) && <p class="desc-text">{aiIntro || project.blurb}</p>
      )}

      {/* Key Highlights */}
      {aiHighlights.length > 0 && (
        <>
          <h2>{T.highlights}</h2>
          <div class="highlights-list">
            {aiHighlights.map((h: string) => (
              <div class="highlight-item">
                <span class="highlight-bullet">&#9656;</span>
                <span>{h}</span>
              </div>
            ))}
          </div>
        </>
      )}

      {/* AI Specs Table */}
      {aiSpecs.length > 0 && (
        <>
          <h2>{T.specs}</h2>
          <table class="spec-table">
            <tr><th>{T.specLabel}</th><th>{T.specDetail}</th></tr>
            {aiSpecs.map((row: string[]) => (
              row[0]
                ? <tr><td>{row[0]}</td><td>{row[1]}</td></tr>
                : <tr><td colspan="2" class="spec-note">{row[1]}</td></tr>
            ))}
          </table>
        </>
      )}

      {/* AI Reward Tiers */}
      {aiTiers.length > 0 ? (
        <>
          <h2>{T.tiers}</h2>
          <div class="tier-grid">
            {aiTiers.map((tier: AiTier) => (
              <div class="tier-card">
                <div class="tier-badge">{tier.backers || ""} {isZH ? "位支持者" : "backers"}</div>
                <div class="tier-name">{tier.name}</div>
                <div class="tier-price">{tier.currency || "$"}{tier.price?.toLocaleString?.() || tier.price}</div>
                {tier.price_usd && <div class="tier-usd">~${tier.price_usd} USD</div>}
                {tier.description && <div class="tier-items">{tier.description}</div>}
              </div>
            ))}
          </div>
        </>
      ) : (
        <div class="cta-box">
          <h3>{T.ctaTiersTitle}</h3>
          <p>{T.ctaTiersDesc.replace("{p}", isKS ? "Kickstarter" : "Indiegogo")}</p>
          <a href={projectUrl} target="_blank" rel="noopener noreferrer" class={isKS ? "btn-primary" : "btn-ig"}>{T.ctaTiersBtn} &rarr;</a>
        </div>
      )}

      {/* AI Risks */}
      {aiRisks && (
        <>
          <h2>{T.risks}</h2>
          {aiRisksStructured ? (
            <div class="risks-list">
              {aiRisksStructured.map((r: string[]) => (
                <div class="risk-card">
                  <div class="risk-card-title">{r[0]}</div>
                  <div class="risk-card-desc">{r[1]}</div>
                </div>
              ))}
            </div>
          ) : (
            <p class="risk-text">{aiRisks}</p>
          )}
        </>
      )}

      <h2>{T.insights}</h2>
      <div class="insights-grid">
        {project.score > 0 && (
          <div class="insight-card">
            <div class="insight-value">{project.score}</div>
            <div class="insight-label">{T.scoreLabel}</div>
          </div>
        )}
        {avgPledged > 0 && (
          <div class="insight-card">
            <div class="insight-value">${avgPledged.toLocaleString()}</div>
            <div class="insight-label">{T.avgPledgeLabel}</div>
          </div>
        )}
        {firstSeen && (
          <div class="insight-card">
            <div class="insight-value">{firstSeen}</div>
            <div class="insight-label">{T.trackedSince}</div>
          </div>
        )}
        <div class="insight-card">
          <div class="insight-value">{pct > 0 ? (pct > 1000 ? `${(pct/100).toFixed(0)}x` : `${pct.toFixed(0)}%`) : "N/A"}</div>
          <div class="insight-label">{T.fundedLabel}</div>
        </div>
      </div>

      <div class="updates-external">
        <span class="updates-icon">&#x1F4DD;</span>
        <div>
          <strong>{T.updatesTitle}</strong>
          <p class="updates-desc">{T.updatesDesc}</p>
          <a href={project.url + "/posts"} target="_blank" rel="noopener noreferrer">{T.updatesLink} &nearr;</a>
        </div>
      </div>
    </div>

    <aside class="detail-sidebar">
      <div class="sidebar-card">
        <h3>{T.creatorSection}</h3>
        <div class="creator-info">
          {project.creator_avatar_medium ? (
            <img src={project.creator_avatar_medium} alt={project.creator_name || "Creator"} class="creator-avatar-img" />
          ) : (
            <div class={`creator-avatar ${isKS ? "avatar-ks" : "avatar-ig"}`}>
              <span>{(project.creator_name || (isKS ? "C" : "O"))[0]}</span>
            </div>
          )}
          <div>
            <div class="creator-name">{T.creatorName}</div>
            {project.location && <div class="creator-desc">{project.location}</div>}
          </div>
        </div>
        {T.creatorBio && <p class="creator-bio">{T.creatorBio}</p>}
      </div>
      <div class="sidebar-card">
        <h3>{T.projectInfo}</h3>
        <div class="project-meta">
          <div class="meta-row">
            <span class="meta-label">{T.platform}</span>
            <span class="meta-value" style={!isKS ? "color:#00b9a0;font-weight:600" : ""}>{isKS ? "Kickstarter" : "Indiegogo"}</span>
          </div>
          <div class="meta-row">
            <span class="meta-label">{T.launched}</span>
            <span class="meta-value">{project.launched_at ? new Date(project.launched_at).toLocaleDateString("en-US", { year: "numeric", month: "short" }) : "N/A"}</span>
          </div>
          <div class="meta-row">
            <span class="meta-label">{T.deadline}</span>
            <span class="meta-value">{project.deadline ? new Date(project.deadline).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" }) : "N/A"}</span>
          </div>
          <div class="meta-row">
            <span class="meta-label">{T.backersMeta}</span>
            <span class="meta-value">{bc.toLocaleString()}</span>
          </div>
          {project.country && (
            <div class="meta-row">
              <span class="meta-label">{T.origin}</span>
              <span class="meta-value">{project.country}</span>
            </div>
          )}
          {project.currency && (
            <div class="meta-row">
              <span class="meta-label">{T.currency}</span>
              <span class="meta-value">{project.currency_symbol || ""}{project.currency}</span>
            </div>
          )}
        </div>
      </div>
      <AdUnit format="rectangle" />
    </aside>
  </section>

  <!-- Related -->
  <section class="related-section">
    <div class="related-header"><h2 class="related-title">{T.relatedTitle}</h2></div>
    <div class="related-grid">
      {related.map((rp) => (
        <a href={`${baseUrl}/project/${rp.slug}`} class="related-card">
          <div class="related-image c1">{rp.image_full ? <img src={rp.image_full} alt={isZH ? (rp.nameZh ?? rp.name) : rp.name} loading="lazy" class="related-img" /> : rp.image_med ? <img src={rp.image_med} alt={isZH ? (rp.nameZh ?? rp.name) : rp.name} loading="lazy" class="related-img" /> : <span>&#x1F4E6;</span>}</div>
          <div class="related-body">
            <div class="related-category">{rp.topnice_category || rp.category}</div>
            <div class="related-title-text">{isZH ? (rp.nameZh ?? rp.name) : rp.name}</div>
            <div class="related-funded">{fm(rp.pledged)}</div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .project-hero { padding: 100px 48px 40px; background: #ffffff; border-bottom: 1px solid #e2e8f0; }
  .project-hero-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 48px; align-items: center; }
  .project-gallery { border-radius: 20px; overflow: hidden; background: #f1f5f9; aspect-ratio: 16/9; display: flex; align-items: center; justify-content: center; position: relative; }
  .gallery-img { width: 100%; height: 100%; object-fit: cover; position: absolute; top: 0; left: 0; }
  .gallery-placeholder { font-size: 120px; z-index: 1; }
  .video-overlay-btn { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 60px; height: 60px; border-radius: 50%; background: rgba(0,0,0,0.55); border: 3px solid rgba(255,255,255,0.85); color: #fff; font-size: 26px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; z-index: 2; }
  .video-overlay-btn:hover { background: rgba(99,102,241,0.85); transform: translate(-50%, -50%) scale(1.1); }
  .ended-overlay { position: absolute; top: 16px; right: 16px; background: #f1f5f9; color: #94a3b8; padding: 6px 14px; border-radius: 8px; font-size: 12px; font-weight: 600; }
  .hero-blurb { font-size: 14px; color: #64748b; line-height: 1.5; margin: 0 0 12px; max-width: 560px; }
  .project-info { padding-top: 8px; }
  .project-category { font-size: 12px; font-weight: 600; color: #f97316; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
  .project-title { font-size: 28px; font-weight: 800; color: #0f172a; line-height: 1.2; margin-bottom: 10px; letter-spacing: -0.3px; }
  .project-funding { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px; padding: 16px 20px; margin-bottom: 16px; }
  .funding-amount { font-size: 28px; font-weight: 800; color: #16a34a; margin-bottom: 2px; }
  .funding-goal { font-size: 13px; color: #64748b; margin-bottom: 12px; }
  .funding-stats { display: flex; gap: 24px; margin-top: 12px; flex-wrap: wrap; }
  .funding-stat { display: flex; flex-direction: column; gap: 2px; }
  .funding-stat-value { font-size: 16px; font-weight: 700; color: #0f172a; }
  .funding-stat-label { font-size: 12px; color: #94a3b8; }
  .funding-stat-link { font-size: 16px; color: #00b9a0; font-weight: 700; cursor: pointer; }
  .ended-notice { background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 8px; padding: 10px 16px; font-size: 13px; color: #64748b; margin-bottom: 16px; text-align: center; }
  .project-actions { display: flex; gap: 12px; }
  .btn-primary { flex: 1; padding: 14px 24px; border-radius: 12px; background: #0f172a; color: #fff; font-size: 15px; font-weight: 600; border: none; cursor: pointer; transition: all 0.2s; text-decoration: none; text-align: center; display: flex; align-items: center; justify-content: center; gap: 8px; font-family: inherit; }
  .btn-primary:hover { background: #1e293b; }
  .btn-secondary { padding: 14px 24px; border-radius: 12px; background: #fff; color: #0f172a; font-size: 15px; font-weight: 600; border: 1px solid #e2e8f0; cursor: pointer; transition: all 0.2s; display: flex; align-items: center; justify-content: center; gap: 8px; font-family: inherit; }
  .btn-secondary:hover { background: #f8fafc; }
  .btn-ig { flex: 1; padding: 14px 24px; border-radius: 12px; background: #00b9a0; color: #fff; font-size: 15px; font-weight: 600; border: none; cursor: pointer; transition: all 0.2s; text-decoration: none; text-align: center; display: flex; align-items: center; justify-content: center; gap: 8px; font-family: inherit; }
  .btn-ig:hover { background: #009e88; }

  .video-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); z-index: 2000; align-items: center; justify-content: center; }
  .video-modal.active { display: flex; }
  .video-modal video { max-width: 90%; max-height: 90%; border-radius: 16px; }
  .video-close { position: absolute; top: 32px; right: 32px; width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,0.2); border: none; color: #fff; font-size: 24px; cursor: pointer; }

