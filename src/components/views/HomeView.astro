---
import Layout from "../../layouts/Layout.astro";
import StatsBar from "../../components/StatsBar.astro";
import FilterBar from "../../components/FilterBar.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import { allProjects } from "../../data/projects";
import { categories } from "../../config/categories";
import { fm, nameOf } from "../../config/format";

interface Props {
  lang: "en" | "zh";
}
const { lang } = Astro.props;

const INITIAL_COUNT = 24;
const LOAD_MORE = 12;
// Sort: live projects first, ended last (applies to all data)
const sortedProjects = [...allProjects].sort((a, b) => {
  if (a.state === 'live' && b.state !== 'live') return -1;
  if (a.state !== 'live' && b.state === 'live') return 1;
  return (b.score || 0) - (a.score || 0);
});
const projects = sortedProjects.slice(0, INITIAL_COUNT);
const projectJson = JSON.stringify(sortedProjects.map(p => ({
  s: p.slug, n: p.name, z: lang === "zh" ? (p.nameZh || "") : "",
  i: p.image_full || p.image_med || p.image_thumb || '',
  p: p.platform === "kickstarter" ? "k" : "i",
  c: p.topnice_category || p.category, d: p.pledged, g: p.goal,
  f: p.percent_funded, st: p.state, l: p.daysLeft || 0, b: p.backers_count,
  sc: p.score || 0, dl: p.deadline || '', la: p.launched_at || ''
})));

// Hero cards: #1 = most pledged, #2 = most backers (unless same project, then #2 pledged)
const byPledged = [...allProjects].sort((a, b) => (b.pledged || 0) - (a.pledged || 0));
const byBackers = [...allProjects].sort((a, b) => (b.backers_count || 0) - (a.backers_count || 0));
const topPledged = byPledged[0];
const topBackers = byBackers[0];
const top2 = topPledged.slug === topBackers.slug
  ? [topPledged, byPledged[1]]
  : [topPledged, topBackers];

const totalRaised = allProjects.reduce((s, p) => s + p.pledged, 0);
const totalBackers = allProjects.reduce((s, p) => s + p.backers_count, 0);
const liveCount = allProjects.filter((p) => p.state === "live").length;

// 标题：中文模式优先 nameZh，与详情页/搜索页一致
const base = lang === "zh" ? "/zh" : "";

// Hero 卡片 meta：中英文案按语言切换
const heroMeta = (p: any) => lang === "zh"
  ? (p.goal > 0 ? '目标 ' + fm(p.goal) + ' · ' : '') + p.backers_count.toLocaleString() + ' 支持者 · ' + (p.daysLeft > 0 ? p.daysLeft + ' 天剩余' : p.state !== 'live' ? '已结束' : '即将结束')
  : (p.goal > 0 ? 'Goal ' + fm(p.goal) : '') + ' ' + p.backers_count.toLocaleString() + ' backers · ' + (p.daysLeft > 0 ? p.daysLeft + ' days left' : p.state !== 'live' ? 'Ended' : '');

const S = lang === "zh" ? {
  h1a: "发现全球", h1b: "硬件众筹", h1c: "新品",
  sub: "每日追踪全球优质硬件众筹项目，一站式发现新奇产品。",
  sectionTitle: "热门项目",
  sectionCount: (n: number) => `${n} 个项目`,
  loading: "加载更多...",
  title: "发现新奇产品",
  description: "TopNice 聚合 Kickstarter 和 Indiegogo 上最具创新力的实体产品。",
  sdDesc: "发现 Kickstarter 和 Indiegogo 上最新的硬件众筹项目，每日更新追踪。",
  empty: "暂无项目",
} : {
  h1a: "Discover the Best", h1b: "Hardware Crowdfunding", h1c: "",
  sub: "Aggregating quality hardware crowdfunding projects worldwide, tracked daily.",
  sectionTitle: "Popular Projects",
  sectionCount: (n: number) => `${n} projects`,
  loading: "Loading more...",
  title: "Discover Amazing New Products",
  description: "TopNice aggregates the most innovative physical products from Kickstarter and Indiegogo. Explore robots, gadgets, hardware, and more — tracked daily.",
  sdDesc: "Discover the best hardware crowdfunding projects from Kickstarter and Indiegogo, curated and tracked daily.",
  empty: "No projects found",
};
---

<Layout
  title={S.title}
  description={S.description}
  lang={lang}
  structuredData={{
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "TopNice",
    url: "https://topnice.com",
    description: S.sdDesc
  }}
>
  <main data-lang={lang}>
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <h1 class={lang === "zh" ? "zh-h1" : ""}>{S.h1a}<span>{S.h1b}</span>{S.h1c}</h1>
        <p>{S.sub}</p>
        <StatsBar
          totalProjects={liveCount}
          totalRaised={fm(totalRaised)}
          totalBackers={fm(totalBackers)}
          lang={lang}
        />
      </div>
      <div class="hero-visual">
        {top2.map((p) => (
          <a href={`${base}/project/${p.slug}`} class="hero-card">
            <div class="hero-card-image">
              {p.image_med ? <img src={p.image_med} alt={nameOf(p)} loading="lazy" class="hero-card-img" /> : <span aria-hidden="true">&#x1F4E6;</span>}
            </div>
            <div class="hero-card-category">{p.topnice_category || p.category}</div>
            <div class="hero-card-title">{nameOf(p)}</div>
            <div class="hero-card-amount">{fm(p.pledged)}</div>
            <div class="hero-card-meta">{heroMeta(p)}</div>
            <div class="hero-card-progress"><div class="hero-card-progress-fill" style={`width: ${p.goal > 0 ? Math.min(p.percent_funded, 100) : 100}%`}></div></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FilterBar lang={lang} categories={categories.filter(c => c.id !== "all")} activeCategory="all" activeSort="popular" totalCount={allProjects.length} />

  <section class="projects">
    <div class="section-header">
      <div class="section-header-left"><div class="section-title">{S.sectionTitle}</div></div>
      <div class="section-count">{S.sectionCount(allProjects.length)}</div>
    </div>
    <div class="project-grid" id="project-grid">
      {projects.length > 0 ? projects.map((p) => (
        <ProjectCard project={p} lang={lang} view="grid" />
      )) : <p>{S.empty}</p>}
    </div>
    <!-- All project data as hidden JSON -->
    <div id="project-data" style="display:none">{projectJson}</div>
    <!-- Sentinel for infinite scroll -->
    <div id="scroll-sentinel" class="scroll-sentinel">
      <span class="scroll-loading" id="scroll-loading" style="display:none;">{S.loading}</span>
    </div>
  </section>
  </main>
</Layout>

<style>
  .hero { padding: 100px 48px 32px; background: #ffffff; border-bottom: 1px solid #e2e8f0; }
  .hero-inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .hero-content h1 { font-size: 48px; font-weight: 800; line-height: 1.1; margin-bottom: 20px; letter-spacing: -1.5px; color: #0f172a; }
  .hero-content h1 span { color: #f97316; display: block; }
  .hero-content h1.zh-h1 span { display: inline; }
  .hero-content p { font-size: 16px; color: #64748b; margin-bottom: 32px; max-width: 480px; }
  .hero-visual { display: flex; gap: 16px; position: relative; }
  .hero-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 24px; padding: 20px; transition: all 0.3s ease; flex: 1; box-shadow: 0 8px 24px rgba(0,0,0,0.06); text-decoration: none; color: inherit; display: block; }
  .hero-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,0.1); }
  .hero-card-image { aspect-ratio: 16/9; border-radius: 16px; margin-bottom: 16px; position: relative; background: linear-gradient(135deg, #fef3c7, #fde68a); display: flex; align-items: center; justify-content: center; font-size: 56px; overflow: hidden; }
  .hero-card-img { width: 100%; height: 100%; object-fit: cover; position: absolute; }
  .hero-card:nth-child(2) .hero-card-image { background: linear-gradient(135deg, #dbeafe, #bfdbfe); }
  .hero-card-category { font-size: 11px; font-weight: 600; color: #f97316; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
  .hero-card-title { font-size: 15px; font-weight: 700; color: #0f172a; margin-bottom: 10px; line-height: 1.4; }
  .hero-card-amount { font-size: 16px; font-weight: 700; color: #16a34a; margin-bottom: 6px; }
  .hero-card-meta { font-size: 12px; color: #64748b; margin-bottom: 14px; }
  .hero-card-progress { height: 6px; background: #e2e8f0; border-radius: 3px; overflow: hidden; }
  .hero-card-progress-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, #22c55e, #16a34a); }
  .projects { padding: 40px 48px 80px; max-width: 1400px; margin: 0 auto; }
  .section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18px; }
  .section-title { font-size: 15px; font-weight: 600; color: #475569; }
  .section-count { font-size: 12px; color: #94a3b8; }
  .project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
  .scroll-sentinel { display: flex; justify-content: center; padding: 40px 0; }
  .scroll-loading { color: #94a3b8; font-size: 14px; }
  @media (max-width: 768px) {
    .hero { padding: 88px 20px 32px; }
    .hero-inner { grid-template-columns: 1fr; gap: 32px; }
    .hero-content h1 { font-size: 32px; }
    .hero-visual { flex-direction: column; }
    .projects { padding: 32px 20px 60px; }
    .project-grid { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  (function() {
    var pageEl = document.querySelector('main');
    var lang = pageEl ? pageEl.getAttribute('data-lang') : 'en';
    var base = lang === 'zh' ? '/zh' : '';
    var STR = lang === 'zh' ? {
      ended: '已结束', days: '天', backers: '支持者', raised: '达成', remaining: '剩余',
      projects: function(n){ return n + ' 个项目'; }
    } : {
      ended: 'Ended', days: 'days', backers: 'backers', raised: 'raised', remaining: 'remaining',
      projects: function(n){ return n + ' projects'; }
    };

    // Inject ProjectCard CSS (Astro scoped CSS not included on this page)
    var css = document.createElement('style');
      css.textContent = '.project-card{background:#fff;border:1px solid #e2e8f0;border-radius:20px;overflow:hidden;transition:all .3s ease;cursor:pointer;display:block;text-decoration:none;color:inherit}.project-card:hover{transform:translateY(-4px);box-shadow:0 20px 40px rgba(0,0,0,0.08);border-color:#cbd5e1}.card-image{width:100%;aspect-ratio:16/9;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;font-size:64px;background:linear-gradient(135deg,#f8fafc,#f1f5f9)}.card-img{width:100%;height:100%;object-fit:cover;position:absolute}.card-emoji{font-size:64px}.card-body{padding:20px}.card-category{font-size:11px;font-weight:600;color:#f97316;text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}.card-title{font-size:15px;font-weight:600;color:#0f172a;margin-bottom:16px;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}.card-progress-area{margin-bottom:16px}.card-progress-header{display:flex;justify-content:space-between;margin-bottom:8px}.card-funded{font-size:18px;font-weight:700;color:#16a34a}.card-percent{font-size:13px;font-weight:600;color:#0f172a;background:#f0fdf4;padding:2px 10px;border-radius:6px}.progress-bar{height:8px;background:#f1f5f9;border-radius:4px;overflow:hidden}.progress-fill{height:100%;border-radius:4px;background:linear-gradient(90deg,#22c55e,#16a34a);transition:width .6s ease}.card-footer{display:flex;justify-content:space-between;font-size:13px;color:#64748b;padding-top:12px;border-top:1px solid #f1f5f9}.card-footer span{display:flex;align-items:center;gap:4px}.ended-badge{position:absolute;top:12px;right:12px;background:#f1f5f9;color:#94a3b8;padding:4px 8px;border-radius:6px;font-size:11px;font-weight:600}.project-grid.list-view{grid-template-columns:repeat(2,1fr)!important}@media(max-width:768px){.project-grid.list-view{grid-template-columns:1fr!important}}.project-list-item{display:flex;gap:12px;padding:12px;background:#fff;border:1px solid #e2e8f0;border-radius:12px;text-decoration:none;color:inherit;transition:all .2s;cursor:pointer;box-sizing:border-box;min-width:0}.project-list-item:hover{box-shadow:0 8px 20px rgba(0,0,0,.06);border-color:#cbd5e1}.list-thumb{width:80px;height:80px;border-radius:10px;overflow:hidden;flex-shrink:0;background:linear-gradient(135deg,#f1f5f9,#e2e8f0);display:flex;align-items:center;justify-content:center;font-size:32px;box-sizing:border-box}.list-thumb-img{width:100%;height:100%;object-fit:cover}.list-content{flex:1;min-width:0;display:flex;flex-direction:column;justify-content:center;gap:4px}.list-meta-top{display:flex;justify-content:space-between;align-items:center}.list-category{font-size:10px;font-weight:600;color:#f97316;text-transform:uppercase;letter-spacing:.4px}.list-funded-compact{font-size:14px;font-weight:700;color:#16a34a}.list-title-row{overflow:hidden}.list-title{font-size:13px;font-weight:600;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.list-progress-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap}.list-progress-bar{flex:1;min-width:60px;height:5px;background:#f1f5f9;border-radius:3px;overflow:hidden}.list-progress-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,#22c55e,#16a34a)}.list-stats{display:flex;align-items:center;gap:8px;font-size:11px;color:#64748b;white-space:nowrap}.list-stat strong{color:#0f172a;font-weight:600}.list-meta-top{display:flex;justify-content:space-between;align-items:center}.list-category{font-size:10px;font-weight:600;color:#f97316;text-transform:uppercase;letter-spacing:.4px}.list-funded-compact{font-size:14px;font-weight:700;color:#16a34a}.list-title-row{overflow:hidden}.list-title{font-size:13px;font-weight:600;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.list-progress-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap}.list-progress-bar{flex:1;min-width:60px;height:5px;background:#f1f5f9;border-radius:3px;overflow:hidden}.list-progress-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,#22c55e,#16a34a)}.list-stats{display:flex;align-items:center;gap:8px;font-size:11px;color:#64748b;white-space:nowrap}.list-stat strong{color:#0f172a;font-weight:600}';
    document.head.appendChild(css);

    var BATCH = 12;
    var INIT_COUNT = 24; // initial render batch size (same as Astro server render)
    var grid = document.getElementById('project-grid');
    var sentinel = document.getElementById('scroll-sentinel');
    var loading = document.getElementById('scroll-loading');
    var dataEl = document.getElementById('project-data');
    if (!grid || !sentinel || !dataEl) return;

    var allData;
    try { allData = JSON.parse(dataEl.textContent); } catch(e) { return; }
    dataEl.remove();

    var index = 24;
    var currentData = allData; // sorted copy for lazy loading after sort/filter

    function esc(s) {
      return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');
    }

    function makeCard(d) {
      var title = d.z || d.n;
      var img = d.i ? '<img src="' + esc(d.i) + '" alt="' + esc(d.n) + '" loading="lazy" class="card-img" />' : '<span class="card-emoji" aria-hidden="true">&#x1F4E6;</span>';
      var ended = d.st !== 'live' ? '<span class="ended-badge">' + STR.ended + '</span>' : '';
      var pct = d.g > 0 ? Math.min(d.f, 9999).toFixed(0) + '%' : '';
      var pctHtml = d.g > 0 ? '<span class="card-percent">' + pct + '</span>' : '';
      var barWidth = d.g > 0 ? Math.min(d.f, 100) : 100;
      var daysHtml = d.l > 0 ? d.l + ' ' + STR.days : STR.ended;
      var fm = '$' + Math.round(d.d || 0).toLocaleString('en-US');
      var bc = (d.b || 0).toLocaleString('en-US');

      var el = document.createElement('div');
      el.innerHTML = '<a href="' + base + '/project/' + esc(d.s) + '" class="project-card" aria-label="' + esc(title) + '">'
        + '<div class="card-image">' + img + ended + '</div>'
        + '<div class="card-body">'
        + '<div class="card-category">' + esc(d.c) + '</div>'
        + '<div class="card-title">' + esc(title) + '</div>'
        + '<div class="card-progress-area">'
        + '<div class="card-progress-header">'
        + '<span class="card-funded">' + fm + '</span>'
        + pctHtml
        + '</div>'
        + '<div class="progress-bar"><div class="progress-fill" style="width:' + barWidth + '%"></div></div>'
        + '</div>'
        + '<div class="card-footer">'
        + '<span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' + daysHtml + '</span>'
        + '<span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>' + bc + '</span>'
        + '</div>'
        + '</div>'
        + '</a>';
      return el.firstElementChild;
    }

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;
        var shown = 0;
        var fn = (currentView === 'list') ? makeListItem : makeCard;
        for (var i = 0; i < BATCH; i++) {
          if (index >= currentData.length) break;
          grid.appendChild(fn(currentData[index]));
          index++;
          shown++;
        }
        if (shown > 0) {
          loading.style.display = 'block';
          setTimeout(function() { loading.style.display = 'none'; }, 400);
        }
        if (index >= currentData.length) {
          observer.unobserve(sentinel);
          sentinel.style.display = 'none';
        }
      });
    }, { rootMargin: '300px' });

    if (index < currentData.length) {
      observer.observe(sentinel);
    } else {
      sentinel.style.display = 'none';
    }

    function makeListItem(d) {
      var title = d.z || d.n;
      var img = d.i ? '<img src="' + esc(d.i) + '" alt="' + esc(d.n) + '" class="list-thumb-img" />' : '<span class="list-emoji">&#x1F4E6;</span>';
      var imgBlock = '<div class="list-thumb">' + img + '</div>';
      var pct = d.g > 0 ? Math.min(d.f, 9999).toFixed(0) + '%' : '';
      var barWidth = d.g > 0 ? Math.min(d.f, 100) : 100;
      var daysHtml = d.l > 0 ? d.l + ' ' + STR.days : STR.ended;
      var fm = '$' + Math.round(d.d || 0).toLocaleString('en-US');
      var bc = (d.b || 0).toLocaleString('en-US');
      var el = document.createElement('div');
      el.innerHTML = '<a href="' + base + '/project/' + esc(d.s) + '" class="project-list-item">'
        + imgBlock
        + '<div class="list-content">'
        + '<div class="list-meta-top"><span class="list-category">' + esc(d.c) + '</span><span class="list-funded-compact">' + fm + '</span></div>'
        + '<div class="list-title-row"><div class="list-title">' + esc(title) + '</div></div>'
        + '<div class="list-progress-row">'
        + '<div class="list-progress-bar"><div class="list-progress-fill" style="width:' + barWidth + '%"></div></div>'
        + '<div class="list-stats"><span class="list-stat"><strong>' + pct + '</strong> ' + STR.raised + '</span><span class="list-stat">&#x23F1; <strong>' + daysHtml + '</strong>' + (lang === 'zh' ? ' ' + STR.remaining : '') + '</span><span class="list-stat">&#x1F465; <strong>' + bc + '</strong> ' + STR.backers + '</span></div>'
        + '</div>'
        + '</div>'
        + '</a>';
      return el.firstElementChild;
    }

    // --- Filter / Sort / View toggle ---
    var currentCategory = 'all';
    var currentSort = 'popular';
    var currentView = 'grid';
    // 品类 ID → 显示名称映射（按钮 data-category 是 kebab-case，数据中 c 是 title-case）
    var catMap = {
      'product-design': 'Product Design',
      'hardware': 'Hardware',
      'gadgets': 'Gadgets',
      'wearables': 'Wearables',
      'diy-electronics': 'DIY Electronics',
      '3d-printing': '3D Printing',
      'camera': 'Camera Gear',
      'robotics': 'Robotics',
      'tech-toys': 'Tech Toys'
    };

    function getFilteredData() {
      // 每次都从原始 allData 浅拷贝，杜绝数组污染
      var filteredRaw = [];
      for (var i = 0; i < allData.length; i++) {
        if (currentCategory === 'all' || allData[i].c === (catMap[currentCategory] || currentCategory)) {
          filteredRaw.push({ s: allData[i].s, n: allData[i].n, z: allData[i].z, i: allData[i].i, p: allData[i].p, c: allData[i].c, d: allData[i].d, g: allData[i].g, f: allData[i].f, st: allData[i].st, l: allData[i].l, b: allData[i].b, sc: allData[i].sc, dl: allData[i].dl, la: allData[i].la });
        }
      }
      // 用 deadline 实时判断是否 ended，不依赖数据库写死的 state 字段
      var now = Date.now();
      function isEnded(item) {
        if (item.st !== 'live') return true;
        if (item.dl) {
          var dl = new Date(item.dl).getTime();
          if (!isNaN(dl) && dl < now) return true;
        }
        return false;
      }
      var live = [];
      var ended = [];
      for (var j = 0; j < filteredRaw.length; j++) {
        if (isEnded(filteredRaw[j])) {
          ended.push(filteredRaw[j]);
        } else {
          live.push(filteredRaw[j]);
        }
      }
      // 统一分支：所有排序都基于干净的 live 数组
      if (currentSort === 'popular') {
        live.sort(function(a,b) { return (b.sc||0) - (a.sc||0); });
      } else if (currentSort === 'newest') {
        live.sort(function(a,b) {
          var da = a.la ? new Date(a.la).getTime() : 0;
          var db = b.la ? new Date(b.la).getTime() : 0;
          return db - da;
        });
      } else if (currentSort === 'ending_soon') {
        live.sort(function(a,b) {
          var da = 99999999999999;
          var db = 99999999999999;
          if (a.dl) { var dateA = new Date(a.dl); if (!isNaN(dateA.getTime())) da = dateA.getTime(); }
          if (b.dl) { var dateB = new Date(b.dl); if (!isNaN(dateB.getTime())) db = dateB.getTime(); }
          return da - db;
        });
      }
      // concat 不修改原数组，返回新数组
      return live.concat(ended);
    }

    function rebuildGrid() {
      // observer 判空防止报错阻断渲染
      if (observer && observer.disconnect) observer.disconnect();
      sentinel.style.display = 'none';
      while (grid.firstChild) { grid.removeChild(grid.firstChild); }
      // 获取排序/筛选后的数据，存入 currentData 供 observer 持续加载
      currentData = getFilteredData();
      var fn = (currentView === 'list') ? makeListItem : makeCard;
      // 用 class 而非 inline style，避免 media query 覆盖不了
      if (currentView === 'list') {
        grid.classList.add('list-view');
      } else {
        grid.classList.remove('list-view');
      }
      // 只渲染前 24 个，后续靠 observer 懒加载
      var count = Math.min(INIT_COUNT, currentData.length);
      for (var i = 0; i < count; i++) {
        grid.appendChild(fn(currentData[i]));
      }
      index = count;
      // 重启 observer
      if (index < currentData.length) {
        sentinel.style.display = '';
        observer.observe(sentinel);
      }
      // Update section count
      var countEl = document.querySelector('.section-count');
      if (countEl) countEl.textContent = STR.projects(currentData.length);
    }

    // Category buttons
    var catBtns = document.querySelectorAll('.filter-btn');
    catBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        catBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        currentCategory = btn.getAttribute('data-category');
        rebuildGrid();
      });
    });

    // Sort tabs
    var sortTabs = document.querySelectorAll('.sort-tab');
    sortTabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        sortTabs.forEach(function(t) { t.classList.remove('active'); });
        tab.classList.add('active');
        currentSort = tab.getAttribute('data-sort');
        rebuildGrid();
      });
    });

    // View toggle
    var viewBtns = document.querySelectorAll('.view-btn');
    viewBtns.forEach(function(btn) {
      btn.addEventListener('click', function() {
        viewBtns.forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        currentView = btn.getAttribute('data-view');
        rebuildGrid();
      });
    });
  })();
</script>
