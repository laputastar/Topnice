---
interface Props {
  progress: number;
}

const { progress } = Astro.props;
const width = Math.min(progress, 100);
---

<div class="progress-bar">
  <div class="progress-fill" style={`width: ${width}%`}></div>
</div>

<style>
  .progress-bar {
    height: 10px;
    background: #e2e8f0;
    border-radius: 5px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    border-radius: 5px;
    background: linear-gradient(90deg, #22c55e, #16a34a);
    transition: width 0.6s ease;
  }
</style>
